# Application environment: development | production
APP_ENV=development

# Postgres connection (async driver). Matches docker-compose.yml in local dev.
DATABASE_URL=postgresql+asyncpg://skillbridge:skillbridge@localhost:5432/skillbridge

# Redis — Arq queue, OAuth sessions, guest run state, and rate-limit counters.
REDIS_URL=redis://localhost:6379/0

# OpenAI — text-embedding-3-small (embeddings) + gpt-4o (project generation).
OPENAI_API_KEY=sk-your-openai-api-key


# Object storage (S3-compatible) — stores extracted resume .txt files.
# LOCAL DEV: the values below point at MinIO, which docker-compose starts and seeds with
#   the bucket automatically. No Cloudflare account needed.
# PRODUCTION: leave R2_ENDPOINT_URL empty (the endpoint is derived from R2_ACCOUNT_ID)
#   and fill the R2_* values from your Cloudflare R2 bucket + API token.
R2_ENDPOINT_URL=http://localhost:9000
R2_ACCOUNT_ID=minio
R2_ACCESS_KEY_ID=minioadmin
R2_SECRET_ACCESS_KEY=minioadmin
R2_BUCKET=skillbridge-resumes

# Google OAuth — the only sign-in method (no passwords).
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Must be allowlisted in the Google Cloud console. This is the default; override in prod.
OAUTH_REDIRECT_URI=http://localhost:8000/auth/google/callback

# Server-side session cookie signing secret. Use 32+ random bytes in production.
SESSION_SECRET=change-me-to-a-long-random-string

# App session cookie (sid) + CSRF cookie.
# Prod (cross-origin Vercel frontend): COOKIE_SECURE=true and COOKIE_SAMESITE=none.
# Local http dev: COOKIE_SECURE=false and COOKIE_SAMESITE=lax.
SESSION_COOKIE_NAME=sid
SESSION_TTL_SECONDS=604800
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# The frontend origin allowed to make credentialed (cookie) requests — the CORS
# allowlist. In prod this is the Vercel URL, e.g. https://skillbridge.vercel.app.
FRONTEND_ORIGIN=http://localhost:3000

# NOTE: the guest rate-limit IP hash uses a daily-rotating salt derived from
# SESSION_SECRET + the UTC date (app/common/rate_limit.py) — there is no separate salt
# variable; rotating SESSION_SECRET rotates it.

# Sentry error tracking. Leave empty to disable in local dev.
SENTRY_DSN=

# Logfire structured logging token. Leave empty to disable in local dev.
LOGFIRE_TOKEN=
