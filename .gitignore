# Caches and build output (regenerated — never committed)
node_modules
.next
out
.venv
.DS_Store
*.tsbuildinfo
__pycache__/
*.pyc
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Local dev service logs written by scripts/dev.sh
backend/.dev-logs/

# Real secrets — never commit (would have to be rotated if exposed).
# Ignore env files anywhere in the tree; the committed *.example templates are kept.
.env
.env.*
!.env.example
!.env.local.example

# Personal, machine-local tooling config (not shared)
.claude/settings.local.json
.claude/*.tmp.*
